datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

enum RoleType {
  SUPER_ADMIN
  ADMIN
  TEACHER
  STUDENT
  PARENT
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum IssueStatus {
  ISSUED
  RETURNED
  OVERDUE
}

model School {
  id           String        @id @default(uuid())
  name         String
  slug         String        @unique // e.g. "dps-dwarka"
  domain       String?       @unique // custom domain support
  logo         String?
  themeColor   String        @default("#7C3AED")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  
  // Relations
  users        User[]
  classes      Class[]
  vehicles     Vehicle[]
  routes       Route[]
  subscriptions SchoolSubscription[]
  auditLogs    AuditLog[]
  libraryBooks LibraryBook[]
  notifications Notification[]
  notices      Notice[]
}

model SubscriptionPlan {
  id           String        @id @default(uuid())
  name         String
  price        Float
  billingCycle String        // MONTHLY, ANNUALLY
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  
  // Relations
  subscriptions SchoolSubscription[]
}

model SchoolSubscription {
  id           String           @id @default(uuid())
  schoolId     String
  school       School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  planId       String
  plan         SubscriptionPlan @relation(fields: [planId], references: [id])
  startDate    DateTime
  endDate      DateTime
  status       String           // ACTIVE, EXPIRED, CANCELLED
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  passwordHash String
  name         String
  role         RoleType
  phone        String?
  address      String?
  profileImage String?
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  
  // Tenancy relation
  schoolId     String?
  school       School?       @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  
  // Relations
  studentProfile Student?
  teacherProfile Teacher?
  parentProfile  Parent?
  sentNotifications Notification[] @relation("SentNotifications")
  userNotifications Notification[] @relation("UserNotifications")
  
  // Messaging
  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
  
  // Notice author
  createdNotices   Notice[]  @relation("CreatedNotices")
  
  // Auditing
  auditLogs        AuditLog[]
}

model Student {
  id              String       @id @default(uuid())
  userId          String       @unique
  rollNumber      String       @unique
  admissionNumber String       @unique
  dateOfBirth     DateTime
  gender          String
  bloodGroup      String?
  
  // Relations
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  classId         String
  studentClass    Class        @relation(fields: [classId], references: [id])
  parentId        String?
  parent          Parent?      @relation(fields: [parentId], references: [id])
  
  attendance      Attendance[]
  marks           Mark[]
  payments        Payment[]
  bookIssues      BookIssue[]
  transactions    FeeTransaction[]
  
  // Transport & Submissions & Documents
  transport       StudentTransport?
  submissions     AssignmentSubmission[]
  certificates    CertificateIssue[]
  
  parentRelations ParentStudentRelation[]
  homeworkSubmissions HomeworkSubmission[]

  @@index([classId])
  @@index([parentId])
}

model Teacher {
  id             String      @id @default(uuid())
  userId         String      @unique
  employeeId     String      @unique
  qualification  String
  specialization String
  joiningDate    DateTime
  
  // Relations
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  classesLed     Class[]     @relation("ClassTeacher")
  subjects       Subject[]
  timetables     Timetable[]
  homeworks      Homework[]
}

model Parent {
  id             String      @id @default(uuid())
  userId         String      @unique
  occupation     String?
  relation       String      // e.g. Father, Mother, Guardian
  
  // Relations
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  students       Student[]
  relations      ParentStudentRelation[]
}

model Class {
  id             String      @id @default(uuid())
  name           String      // e.g. "Class 10", "B.Tech Year 1"
  section        String      // e.g. "A", "Section B"
  roomNumber     String?
  
  // Tenancy relation
  schoolId       String?
  school         School?     @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  
  // Relations
  classTeacherId String?
  classTeacher   Teacher?    @relation("ClassTeacher", fields: [classTeacherId], references: [id])
  students       Student[]
  subjects       Subject[]
  fees           Fee[]
  timetables     Timetable[]
  assignments    Assignment[]
  attendance     Attendance[]
  homeworks      Homework[]
  notices        Notice[]
}

model Subject {
  id          String       @id @default(uuid())
  name        String       // e.g. "Mathematics", "Hindi"
  code        String       @unique // e.g. "MATH101"
  
  // Relations
  classId     String
  subjectClass Class       @relation(fields: [classId], references: [id])
  teacherId   String?
  teacher     Teacher?     @relation(fields: [teacherId], references: [id])
  
  exams       Exam[]
  timetables  Timetable[]
  assignments Assignment[]
  homeworks   Homework[]

  @@index([classId])
  @@index([teacherId])
}

model Attendance {
  id        String           @id @default(uuid())
  date      DateTime
  status    AttendanceStatus
  remarks   String?
  
  // Relations
  studentId String
  student   Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  classId   String
  attendanceClass Class      @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@index([studentId, date])
  @@index([classId])
}

model Exam {
  id           String      @id @default(uuid())
  name         String      // e.g. "Term 1 Final", "Mid-Semester"
  type         String      // e.g. "Written", "Practical"
  date         DateTime
  maxMarks     Float
  passingMarks Float
  isPublished  Boolean     @default(false)
  
  // Relations
  subjectId    String
  subject      Subject     @relation(fields: [subjectId], references: [id])
  marks        Mark[]
}

model Mark {
  id            String   @id @default(uuid())
  marksObtained Float
  remarks       String?
  
  // Relations
  studentId     String
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  examId        String
  exam          Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([examId])
}

model Fee {
  id        String     @id @default(uuid())
  title     String     // e.g. "Tuition Fee - Q1", "Lab Exam Fee"
  amount    Float
  dueDate   DateTime
  
  // Relations
  classId   String
  feeClass  Class      @relation(fields: [classId], references: [id])
  payments  Payment[]
  transactions FeeTransaction[]
}

model Payment {
  id                String        @id @default(uuid())
  studentId         String
  student           Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  feeId             String
  fee               Fee           @relation(fields: [feeId], references: [id])
  amountPaid        Float         // maps to amount
  currency          String        @default("INR")
  paymentMethod     String        @default("ONLINE") // Cash, UPI, Card, NetBanking, etc.
  transactionId     String?       @unique
  razorpayOrderId   String?       @unique
  razorpayPaymentId String?       @unique
  razorpaySignature String?
  status            PaymentStatus @default(PENDING)
  receiptNumber     String        @unique
  paidAt            DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @default(now()) @updatedAt

  @@index([studentId])
  @@index([feeId])
}

model Timetable {
  id        String   @id @default(uuid())
  dayOfWeek String   // MONDAY, TUESDAY, etc.
  startTime String   // e.g. "09:00"
  endTime   String   // e.g. "09:45"
  roomNumber String?
  
  // Relations
  classId   String
  timetableClass Class @relation(fields: [classId], references: [id])
  subjectId String
  subject   Subject  @relation(fields: [subjectId], references: [id])
  teacherId String
  teacher   Teacher  @relation(fields: [teacherId], references: [id])
  
  isDeleted Boolean  @default(false)

  @@index([classId])
  @@index([teacherId])
  @@index([subjectId])
}

model Assignment {
  id          String   @id @default(uuid())
  title       String
  description String
  dueDate     DateTime
  filePath    String?  // URL/path to file
  
  // Relations
  classId     String
  assignmentClass Class @relation(fields: [classId], references: [id])
  subjectId   String
  subject     Subject  @relation(fields: [subjectId], references: [id])
  
  submissions AssignmentSubmission[]
}

model AssignmentSubmission {
  id             String     @id @default(uuid())
  assignmentId   String
  assignment     Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  studentId      String
  student        Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  submissionDate DateTime   @default(now())
  status         String     // SUBMITTED, GRADED, LATE
  filePath       String?
  marksObtained  Float?
  feedback       String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([assignmentId])
  @@index([studentId])
}

model Notification {
  id            String   @id @default(uuid())
  title         String
  message       String
  recipientRole RoleType // All, SUPER_ADMIN, ADMIN, TEACHER, STUDENT, PARENT
  isAnnouncement Boolean @default(false)
  isRead        Boolean  @default(false)
  createdAt     DateTime @default(now())
  
  // Tenancy relation
  schoolId      String?
  school        School?  @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  
  // Relations
  senderId      String?
  sender        User?    @relation("SentNotifications", fields: [senderId], references: [id])
  userId        String?
  user          User?    @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
}

model LibraryBook {
  id                String      @id @default(uuid())
  title             String
  author            String
  isbn              String      @unique
  quantity          Int
  availableQuantity Int
  location          String?     // e.g. "Rack A, Shelf 3"
  
  // Tenancy relation
  schoolId          String?
  school            School?     @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  
  // Relations
  issues            BookIssue[]
}

model BookIssue {
  id         String      @id @default(uuid())
  issueDate  DateTime    @default(now())
  dueDate    DateTime
  returnDate DateTime?
  status     IssueStatus @default(ISSUED)
  fineAmount Float       @default(0.0)
  
  // Relations
  bookId     String
  book       LibraryBook @relation(fields: [bookId], references: [id], onDelete: Cascade)
  studentId  String
  student    Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([bookId])
}

model ContactSubmission {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  createdAt DateTime @default(now())
}

model FeeTransaction {
  id                String    @id @default(uuid())
  razorpayOrderId   String    @unique
  razorpayPaymentId String?   @unique
  razorpaySignature String?
  amount            Float
  currency          String    @default("INR")
  status            String    // PENDING, SUCCESS, FAILED
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  // Relations
  feeId             String
  fee               Fee       @relation(fields: [feeId], references: [id], onDelete: Cascade)
  studentId         String
  student           Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([feeId])
}

model Message {
  id          String   @id @default(uuid())
  senderId    String
  sender      User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  recipientId String
  recipient   User     @relation("ReceivedMessages", fields: [recipientId], references: [id], onDelete: Cascade)
  content     String
  isRead      Boolean  @default(false)
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([senderId])
  @@index([recipientId])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  details   String
  ipAddress String?
  schoolId  String?
  school    School?  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([schoolId])
}

model CertificateIssue {
  id                String   @id @default(uuid())
  studentId         String
  student           Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  certificateType   String
  certificateNumber String   @unique
  issuedDate        DateTime @default(now())
  remarks           String?

  @@index([studentId])
}

model Route {
  id             String             @id @default(uuid())
  name           String
  startLocation  String
  endLocation    String
  stops          String
  transportFee   Float              @default(0.0)
  schoolId       String
  school         School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  
  vehicles       Vehicle[]
  assignments    StudentTransport[]

  @@index([schoolId])
}

model Vehicle {
  id           String             @id @default(uuid())
  regNumber    String             @unique
  model        String
  capacity     Int
  driverName   String
  driverPhone  String?
  schoolId     String
  school       School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  routeId      String?
  route        Route?             @relation(fields: [routeId], references: [id], onDelete: SetNull)
  
  assignments  StudentTransport[]

  @@index([schoolId])
  @@index([routeId])
}

model StudentTransport {
  id        String   @id @default(uuid())
  studentId String   @unique
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  routeId   String
  route     Route    @relation(fields: [routeId], references: [id], onDelete: Cascade)
  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  @@index([routeId])
  @@index([vehicleId])
}

enum NoticeType {
  SCHOOL
  CLASS
  EXAM
  FEE
  EMERGENCY
}

model ParentStudentRelation {
  id         String   @id @default(uuid())
  parentId   String
  parent     Parent   @relation(fields: [parentId], references: [id], onDelete: Cascade)
  studentId  String
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  relation   String   // e.g. FATHER, MOTHER, GUARDIAN
  createdAt  DateTime @default(now())

  @@unique([parentId, studentId])
  @@index([parentId])
  @@index([studentId])
}

model Notice {
  id          String     @id @default(uuid())
  title       String
  content     String     // rich text content
  type        NoticeType
  isPinned    Boolean    @default(false)
  attachment  String?    // URL/path to file
  isDeleted   Boolean    @default(false)
  
  // Tenancy relation
  schoolId    String?
  school      School?    @relation(fields: [schoolId], references: [id], onDelete: SetNull)

  // Target class (null for general school notices)
  classId     String?
  targetClass Class?     @relation(fields: [classId], references: [id], onDelete: SetNull)
  
  // Creator
  authorId    String?
  author      User?      @relation("CreatedNotices", fields: [authorId], references: [id], onDelete: SetNull)

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([schoolId])
  @@index([classId])
  @@index([authorId])
}

model Homework {
  id            String   @id @default(uuid())
  title         String
  description   String
  dueDate       DateTime
  attachment    String?  // File URL
  isDeleted     Boolean  @default(false)
  
  // Relations
  classId       String
  homeworkClass Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  subjectId     String
  subject       Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacherId     String
  teacher       Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  
  submissions   HomeworkSubmission[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([classId])
  @@index([subjectId])
  @@index([teacherId])
}

model HomeworkSubmission {
  id             String   @id @default(uuid())
  homeworkId     String
  homework       Homework @relation(fields: [homeworkId], references: [id], onDelete: Cascade)
  studentId      String
  student        Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  submissionDate DateTime @default(now())
  status         String   // SUBMITTED, GRADED, LATE, PENDING
  filePath       String?  // File URL
  marksObtained  Float?
  feedback       String?
  isDeleted      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([homeworkId, studentId])
  @@index([homeworkId])
  @@index([studentId])
}
