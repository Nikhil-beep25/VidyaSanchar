# Backend Environment Configurations
PORT=5001
NODE_ENV=production
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"
JWT_SECRET="your_jwt_access_secret_token"
JWT_REFRESH_SECRET="your_jwt_refresh_secret_token"
ALLOWED_ORIGINS="http://localhost:5173,https://your-app.vercel.app"

# Frontend Environment Configurations (Vercel)
# Set VITE_API_URL if the frontend needs to call a backend hosted on Render/Railway.
# If left blank, it defaults to relative requests (/api) which can be rewritten on Vercel.
VITE_API_URL=""
